                },
                "network_code": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                },
                "point_code": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                },
                "surname": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        }
    },
