                },
                "surname": {
                    "type": "string",
                    "minLength": 2
                },
                "token": {
                    "type": "string"
                }
            }
        },
        "internal_ports_http_handlers_auth.registerConfirmResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "refresh_token": {
                    "type": "string"
                }
            }
        },
        "internal_ports_http_handlers_auth.registerStaffRequest": {
            "type": "object",
